{
  "expo": {
    "name": "Layla",
    "slug": "layla",
    "scheme": "layla",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0B16"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.layla.ios",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Layla uses your microphone for voice messages so you can talk to her instead of typing.",
        "NSPhotoLibraryAddUsageDescription": "Layla saves your natal chart to your Photos when you tap Save.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesAppleSignIn": true,
      "associatedDomains": []
    },
    "android": {
      "package": "app.layla.android",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0B16"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "RECORD_AUDIO",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-audio",
        {
          "microphonePermission": "Layla uses your microphone for voice messages so you can talk to her instead of typing."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "61dc416b-8110-445f-944e-4fc21f3bfea8"
      }
    },
    "owner": "gombicreations",
    "runtimeVersion": "exposdk:54.0.0",
    "updates": {
      "url": "https://u.expo.dev/61dc416b-8110-445f-944e-4fc21f3bfea8"
    }
  }
}
